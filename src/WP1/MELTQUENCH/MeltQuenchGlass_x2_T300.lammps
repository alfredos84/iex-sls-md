#=== Initialization of velocities at Tstart K
velocity all create ${Tstart} 4928459 rot yes mom yes dist gaussian
velocity all create 3000 4928459 rot yes mom yes dist gaussian


#=== Melt a 3000 K
fix             MELT all npt temp ${Tstart} ${Tstart} $(100.0*dt) iso 0 0 $(1000.0*dt)
fix             MELT all npt temp 3000 ${Tstart} $(100.0*dt) iso 0 0 $(1000.0*dt)
fix             MELT all npt temp 3000 3000 $(100.0*dt) iso 0 0 $(1000.0*dt)
fix             MELT all npt temp 3000 3000 0.10000000000000000555 iso 0 0 $(1000.0*dt)
fix             MELT all npt temp 3000 3000 0.10000000000000000555 iso 0 0 1
run             ${npt_1}
run             50000
