
# Variables
variable        dt              equal 0.002     # Time step en ps
variable        n_molecules     equal 7000      #  n° atoms = n° molecules * 2.9

################################################################################
###--- CREATE RANDOM STRUCTURE ---###
include         RandomStructure.in
################################################################################
###--- CREATE THE INITIAL RANDOM STRUCTURE ---###

# Number of atoms according to composition
# 75-SiO2, (15-x)-Na2O, 10-CaO, x-K2O
variable        n_Si            equal round($(v_n_molecules*0.75))             # Si
variable        n_Si            equal round(5250)             
variable        n_O             equal round($(v_n_molecules*1.75))             # O
variable        n_O             equal round(12250)             
variable        n_Ca            equal round($(0.10*v_n_molecules))             # Ca
variable        n_Ca            equal round(700)             
variable        n_Na            equal round($(0.02*(15-v_x)*v_n_molecules))    # Na
variable        n_Na            equal round(1540)    
variable        n_K             equal round($(0.02*v_x*v_n_molecules))         # Ka
variable        n_K             equal round(560)         


# Total number of atoms
variable        n_atoms         equal $(v_n_Si + v_n_O + v_n_Ca + v_n_Na + v_n_K)
variable        n_atoms         equal 20300
variable        density         equal ${target_density}   # g/cm³
variable        density         equal 2.45889   


# Molar masses(u)
variable        m_Si equal 	28.085   # Silicon mass (Si)
variable        m_O  equal	15.999   # Oxigen mass (O)
variable        m_Ca equal	40.078   # Calcium mass (Ca)
variable        m_Na equal	22.990   # Sodium mass (Na)
variable        m_K  equal	39.098   # Potassium mass (K)
variable	    m_total equal $((v_m_Si*v_n_Si+v_m_O*v_n_O+v_m_Ca*v_n_Ca+v_m_Na*v_n_Na+v_m_K*v_n_K)/v_NAvog)
variable	    m_total equal 7.1203600132846217438e-19


# Volume and Box size (Å)
variable        volume equal $((v_m_total / v_density)*1e24) # volume in A³
variable        volume equal 289576.19142314704368 
variable        L_box equal $(v_volume^(1.0/3.0))
variable        L_box equal 66.158799692748843313

region          simbox block 0 ${L_box} 0 ${L_box} 0 ${L_box} units box
region          simbox block 0 66.1587996927488 0 ${L_box} 0 ${L_box} units box
region          simbox block 0 66.1587996927488 0 66.1587996927488 0 ${L_box} units box
region          simbox block 0 66.1587996927488 0 66.1587996927488 0 66.1587996927488 units box
create_box      5 simbox
Created orthogonal box = (0 0 0) to (66.1588 66.1588 66.1588)
  3 by 4 by 4 MPI processor grid


# Place atoms randomly
create_atoms 1 random ${n_Si} 12347 simbox overlap 1.2 maxtry 200
create_atoms 1 random 5250 12347 simbox overlap 1.2 maxtry 200
Created 5250 atoms
  using lattice units in orthogonal box = (0 0 0) to (66.1588 66.1588 66.1588)
  create_atoms CPU = 0.090 seconds
create_atoms 2 random ${n_O}  56786 simbox overlap 1.2 maxtry 200
create_atoms 2 random 12250  56786 simbox overlap 1.2 maxtry 200
Created 12250 atoms
  using lattice units in orthogonal box = (0 0 0) to (66.1588 66.1588 66.1588)
  create_atoms CPU = 0.247 seconds
create_atoms 3 random ${n_Ca} 23466 simbox overlap 1.2 maxtry 200
create_atoms 3 random 700 23466 simbox overlap 1.2 maxtry 200
Created 700 atoms
  using lattice units in orthogonal box = (0 0 0) to (66.1588 66.1588 66.1588)
  create_atoms CPU = 0.022 seconds
create_atoms 4 random ${n_Na} 67850 simbox overlap 1.2 maxtry 200
create_atoms 4 random 1540 67850 simbox overlap 1.2 maxtry 200
Created 1540 atoms
  using lattice units in orthogonal box = (0 0 0) to (66.1588 66.1588 66.1588)
  create_atoms CPU = 0.046 seconds
create_atoms 5 random ${n_K}  88853 simbox overlap 1.2 maxtry 200
create_atoms 5 random 560  88853 simbox overlap 1.2 maxtry 200
Created 560 atoms
  using lattice units in orthogonal box = (0 0 0) to (66.1588 66.1588 66.1588)
  create_atoms CPU = 0.018 seconds

################################################################################
###--- INTERATOMIC POTENTIAL ---###
include         ../BMP_files/bmp_SiO_CaNaK.mod
# Bertani et al. (2022). JACS
# "include BMP_files/bmp_SiO_CaNaK.mod" in input.lammps
# Choose the type of atoms

################################################################################
###--- DEFINE GROUPS FOR SPECIES ---###
group Si type 1
5250 atoms in group Si
group O  type 2
12250 atoms in group O
group Ca type 3
700 atoms in group Ca
group Na type 4
1540 atoms in group Na
group K  type 5
560 atoms in group K

# Masses
mass    1 28.086    # Si
mass    2 15.9994   # O
mass    3 40.078    # Ca
mass    4 22.99     # Na
mass    5 39.100    # K

# Charges (Pedone/PMMCS effective charges)
set     type 1 charge  2.4000   # Si
Setting atom values ...
  5250 settings made for charge
set     type 2 charge -1.2000   # O
Setting atom values ...
  12250 settings made for charge
set     type 3 charge  1.2000   # Ca
Setting atom values ...
  700 settings made for charge
set     type 4 charge  0.6000   # Na
Setting atom values ...
  1540 settings made for charge
set     type 5 charge  0.6000   # K
Setting atom values ...
  560 settings made for charge

variable	rvdw equal 7.0
pair_style hybrid/overlay coul/dsf 0.2 12.0 table spline 10000 buck 7.0 nb3b/screened
pair_coeff * * coul/dsf
#kspace_style pppm 1.0e-5


# pair_coeff    *    *           table "./Table_None.dat"         NONE  ${rvdw}
pair_coeff    1    2           table ../BMP_files/Table_PMMCS-Si-O.dat      albe  ${rvdw}
pair_coeff    1    2           table ../BMP_files/Table_PMMCS-Si-O.dat      albe  7
WARNING: 3 of 3950 force values in table albe are inconsistent with -dE/dr.
WARNING:  Should only be flagged at inflection points (src/pair_table.cpp:466)
pair_coeff    2    2           table ../BMP_files/Table_PMMCS-O-O.dat       albe  ${rvdw}
pair_coeff    2    2           table ../BMP_files/Table_PMMCS-O-O.dat       albe  7
WARNING: 10 of 3950 force values in table albe are inconsistent with -dE/dr.
WARNING:  Should only be flagged at inflection points (src/pair_table.cpp:466)
pair_coeff    3    2           table ../BMP_files/Table_PMMCS-Ca-O.dat      albe  ${rvdw}
pair_coeff    3    2           table ../BMP_files/Table_PMMCS-Ca-O.dat      albe  7
WARNING: 3 of 3950 force values in table albe are inconsistent with -dE/dr.
WARNING:  Should only be flagged at inflection points (src/pair_table.cpp:466)
pair_coeff    4    2           table ../BMP_files/Table_PMMCS-Na-O.dat      albe  ${rvdw}
pair_coeff    4    2           table ../BMP_files/Table_PMMCS-Na-O.dat      albe  7
WARNING: 11 of 3950 force values in table albe are inconsistent with -dE/dr.
WARNING:  Should only be flagged at inflection points (src/pair_table.cpp:466)
pair_coeff    5    2           table ../BMP_files/Table_BMP-K-O.dat         albe  ${rvdw}
pair_coeff    5    2           table ../BMP_files/Table_BMP-K-O.dat         albe  7
WARNING: 10 of 3995 force values in table albe are inconsistent with -dE/dr.
WARNING:  Should only be flagged at inflection points (src/pair_table.cpp:466)

# buckingham only for Si, Al
pair_coeff    1    1           buck  7.093669 0.975598 0.0

# tbp only for Si, with O
pair_coeff * * nb3b/screened ../BMP_files/BMP-SiP.nb3b.shrm Si O NULL NULL NULL
neighbor        2.0 bin
neigh_modify    delay 10 check yes

################################################################################
###--- SAVE INITIAL CONFIGURATION ---###
write_data      Initial_random_structure_x${x}_T${T_end}.data
write_data      Initial_random_structure_x4_T${T_end}.data
write_data      Initial_random_structure_x4_T300.data
System init for write_data ...
Neighbor list info ...
  update: every = 1 steps, delay = 10 steps, check = yes
  max neighbors/atom: 2000, page size: 100000
  master list distance cutoff = 14
  ghost atom cutoff = 14
  binsize = 7, bins = 10 10 10
  5 neighbor lists, perpetual/occasional/extra = 5 0 0
  (1) pair coul/dsf, perpetual
      attributes: half, newton on
      pair build: half/bin/atomonly/newton
      stencil: half/bin/3d
      bin: standard
  (2) pair table, perpetual, skip trim from (1)
      attributes: half, newton on, cut 9
      pair build: skip/trim
      stencil: none
      bin: none
  (3) pair buck, perpetual, skip trim from (1)
      attributes: half, newton on, cut 9
      pair build: skip/trim
      stencil: none
      bin: none
  (4) pair nb3b/screened, perpetual, skip from (5)
      attributes: full, newton on, cut 4
      pair build: skip
      stencil: none
      bin: none
  (5) neighbor class addition, perpetual
      attributes: full, newton on, cut 4
      pair build: full/bin/atomonly
      stencil: full/bin/3d
      bin: standard

################################################################################
###--- SIMULATION ---###
variable        Tend            equal ${T_end}  # Final temperature in Kelvin (parsed variable)
variable        Tend            equal 300  
variable        Tstart          equal 3000.0    # Initial temperature in Kelvin

#=== Cooling rate, quenching steps and NPT steps
variable        cooling_rate    equal 1.00      # in K/ps
variable        quench_steps    equal round($((v_Tstart-v_Tend)/(v_dt*v_cooling_rate)))
variable        quench_steps    equal round(1350000)
variable        npt_1           equal 50000     # 100 ps = 50000 steps at 0.002 ps/step
variable        npt_2           equal 50000     # 100 ps = 50000 steps at 0.002 ps/step

#=== Print on screen the initial information
print "Si = $(v_n_Si), O = $(v_n_O), Ca = $(v_n_Ca) , Na = $(v_n_Na), K = $(v_n_K) atoms"
Si = 5250, O = 12250, Ca = 700 , Na = 1540, K = 560 atoms
print "Total atoms = ${n_atoms}"
Total atoms = 20300
print "Length box = ${L_box}"
Length box = 66.1587996927488
print "Density = $(v_density) g/cm3"
Density = 2.4588899999999997981 g/cm3
print "Cooling rate = $(v_cooling_rate) K/ps"
Cooling rate = 1 K/ps
print "Quenching steps = $(v_quench_steps)"
Quenching steps = 1350000


thermo          1000
thermo_style    custom step temp press pe etotal vol lx ly lz density

reset_timestep  0
min_style       cg
minimize        1.0e-6 1.0e-8 1000 10000
